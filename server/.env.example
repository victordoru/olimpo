# Copia este archivo a .env y rellena los valores
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/olimpo

# Contraseña para entrar a la web (un solo usuario: tú)
APP_PASSWORD=cambiame

# Secreto para firmar las sesiones (pon una cadena larga aleatoria)
JWT_SECRET=cambiame-por-algo-largo-y-aleatorio

# Clave que usará Hermes para llamar a la API (distinta de tu contraseña)
AGENT_API_KEY=genera-una-clave-larga-aleatoria

# Parser de facturas en lenguaje natural con OpenRouter (opcional)
OPENROUTER_API_KEY=tu-clave-de-openrouter
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_SITE_URL=http://localhost:4000
OPENROUTER_APP_NAME=Olimpo

# Conexión con el banco vía GoCardless Bank Account Data (antes Nordigen).
# Acceso PSD2 de solo lectura a tus movimientos. Gratis: crea una cuenta en
# https://bankaccountdata.gocardless.com/ y genera un par de claves.
# Sin estas claves, la sección Finanzas funciona igual (manual + CSV); solo
# queda deshabilitado el botón de conectar/sincronizar el banco.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
# A dónde vuelve el banco tras autorizar (en producción, la URL pública del VPS).
GOCARDLESS_REDIRECT_URI=http://localhost:5173/finanzas
